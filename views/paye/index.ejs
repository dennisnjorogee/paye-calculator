<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <title>
      Kenya PAYE Calculator | Calculate PAYE Tax, Net Salary & Deductions
    </title>

    <meta
      name="description"
      content="Free Kenya PAYE Calculator. Calculate PAYE tax, net salary, NSSF, SHIF, Housing Levy, and other statutory deductions instantly using the latest Kenya tax rates."
    />

    <meta
      name="keywords"
      content="Kenya PAYE Calculator, PAYE Calculator Kenya, PAYE tax calculator, Kenya salary calculator, net salary calculator Kenya, payroll calculator Kenya, KRA PAYE calculator"
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="canonical" href="https://yourdomain.com/paye-calculator" />

    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body data-api-url="<%= API_URL %>">
    <%- include('../shared/header') %>

    <main>
      <section>
        <h1>Kenya PAYE Calculator</h1>

        <p>
          A PAYE (Pay As You Earn) Calculator helps employees and employers in
          Kenya determine the income tax payable based on the Kenya Revenue
          Authority (KRA) tax bands. It also considers statutory deductions such
          as NSSF and SHIF to estimate net salary.
        </p>

        <h2>PAYE Tax Bands (Current Kenya Rates)</h2>

        <table>
          <thead>
            <tr>
              <th>Monthly Taxable Income (KES)</th>
              <th>Tax Rate</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>0 - 24,000</td>
              <td>10%</td>
            </tr>
            <tr>
              <td>Next 8,333</td>
              <td>25%</td>
            </tr>
            <tr>
              <td>Next 467,667</td>
              <td>30%</td>
            </tr>
            <tr>
              <td>Next 300,000</td>
              <td>32.5%</td>
            </tr>
            <tr>
              <td>Above 800,000</td>
              <td>35%</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section id="paye-form-section">
        <form id="paye-form" autocomplete="off">
          <h2>Calculate Your PAYE Tax and Net Salary</h2>

          <div>
            <label for="gross-pay">Gross Monthly Salary (KES)</label>
            <input
              id="gross-pay"
              name="grossPay"
              type="number"
              placeholder="0.00"
              min="0"
              step="0.01"
              required
            />
          </div>

          <p id="error-message" hidden></p>

          <button type="submit">Calculate</button>
        </form>
      </section>

      <section id="results" hidden aria-live="polite">
        <div class="results-success">
          <p id="success-message"></p>
        </div>

        <h2>Results</h2>

        <table>
          <tbody>
            <tr>
              <td>Gross Salary</td>
              <td id="gross-salary">KES 0.00</td>
            </tr>
            <tr>
              <td>NSSF (Tier I & II)</td>
              <td id="nssf">KES 0.00</td>
            </tr>
            <tr>
              <td>SHIF</td>
              <td id="shif">KES 0.00</td>
            </tr>
            <tr>
              <td>Housing Levy</td>
              <td id="housing-levy">KES 0.00</td>
            </tr>
            <tr>
              <td>Taxable Income</td>
              <td id="taxable-income">KES 0.00</td>
            </tr>
            <tr>
              <td>PAYE</td>
              <td id="paye">KES 0.00</td>
            </tr>
            <tr>
              <td>Total Deductions</td>
              <td id="deductions">KES 0.00</td>
            </tr>
            <tr>
              <td><strong>Net Salary</strong></td>
              <td id="net-salary"><strong>KES 0.00</strong></td>
            </tr>
          </tbody>
        </table>

        <button id="reset-btn">Reset</button>
      </section>
    </main>

    <%- include('../shared/footer') %>

    <script src="/js/paye.js" defer></script>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />

    <title>NSSF Calculator Kenya | Calculate NSSF Contributions Online</title>

    <meta
      name="description"
      content="Free Kenya NSSF Calculator. Calculate your employee and employer NSSF contributions instantly using the latest Kenya NSSF rates. Accurate, fast, and easy to use."
    />

    <meta
      name="keywords"
      content="NSSF Calculator Kenya, Kenya NSSF Calculator, NSSF contribution calculator, employee NSSF, employer NSSF, Kenya payroll calculator"
    />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="canonical" href="https://yourdomain.com/nssf-calculator" />

    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body data-api-url="<%= API_URL %>">
    <%- include('../shared/header') %>

    <main>
      <section>
        <h1>NSSF Calculator Kenya</h1>

        <p>
          National Social Security Fund (NSSF) Calculator helps employees and
          employers determine their monthly pension contributions under the NSSF
          Act, 2013 (Tier I & II). The fund promotes long-term savings for
          retirement and is mandatory for all employed persons in Kenya.
        </p>

        <h2>NSSF Contribution Rates - Current Kenya Rates</h2>

        <table>
          <thead>
            <tr>
              <th>Tier</th>
              <th>Monthly Pensionable Income (KES)</th>
              <th>Contribution (6% Employee + 6% Employer)</th>
            </tr>
          </thead>

          <tbody>
            <tr>
              <td>tier 1</td>
              <td>Up to 9,000</td>
              <td>6% of income (max KES 540 per side)</td>
            </tr>
            <tr>
              <td>tier 2</td>
              <td>9,001 - 108,000</td>
              <td>6% of income (max KES 5,940 per side)</td>
            </tr>
          </tbody>
        </table>
      </section>

      <section id="nssf-form-section">
        <form id="nssf-form" autocomplete="off">
          <h2>NSSF Calculator</h2>

          <div>
            <label for="gross-pay">Gross Monthly Salary (KES)</label>
            <input
              id="gross-pay"
              name="grossPay"
              type="number"
              placeholder="0.00"
              min="0"
              step="0.01"
              required
            />
          </div>

          <p id="error-message" hidden></p>

          <button type="submit">Calculate</button>
        </form>
      </section>

      <section id="results" hidden aria-live="polite">
        <div class="results-success">
          <p id="success-message"></p>
        </div>

        <h2>Results</h2>

        <table>
          <tbody>
            <tr>
              <td>Gross Salary</td>
              <td id="gross-salary">KES 0.00</td>
            </tr>
            <tr>
              <td><strong>NSSF (Tier I & II)</strong></td>
              <td id="nssf"><strong>KES 0.00</strong></td>
            </tr>
          </tbody>
        </table>

        <button id="reset-btn">Reset</button>
      </section>
    </main>

    <%- include('../shared/footer') %>

    <script src="/js/nssf.js" defer></script>
  </body>
</html>
